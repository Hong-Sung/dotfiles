
IgnoreUnknown UseKeychain

Include ~/.ssh/config.local

Host *
    Port 22
    SetEnv TERM=xterm-256color
    #SendEnv COLORTERM TERM_PROGRAM TERM_PROGRAM_VERSION

    ForwardAgent yes
    XAuthLocation /opt/X11/bin/xauth

Match exec "sh -c 'test $(uname) = Darwin'"
    UseKeychain yes
    AddKeysToAgent yes


Host github.com
    HostName github.com
    User git
