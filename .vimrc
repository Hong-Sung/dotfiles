set nocompatible
set encoding=utf-8
set fileencodings=utf-8,cp949
set tags=./tags,../tags,../../tags,../../../tags

" tab
set expandtab
set shiftwidth=4
set softtabstop=4
set tabstop=4

" 편의성
set number
set relativenumber
set hlsearch
set incsearch
set ignorecase
set smartcase
set cursorline

" 시각적
set laststatus=2
set wildmenu

